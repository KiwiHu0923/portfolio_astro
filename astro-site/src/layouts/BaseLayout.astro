---
// BaseLayout.astro - The main template that wraps all pages
// This is equivalent to your Flask base.html template
//
// KEY DIFFERENCES FROM JINJA2:
// - {{ variable }}  →  {variable}
// - url_for('static', filename='css/styles.css')  →  /css/styles.css
// - url_for('home')  →  /
// - request.path  →  Astro.url.pathname
// - {% block content %}  →  <slot />

// Import ClientRouter for smooth page navigation animations
// Note: In Astro 5+, ViewTransitions was renamed to ClientRouter
// This is an Astro built-in feature - no npm install needed!
import { ClientRouter } from 'astro:transitions';

// Import ThemeToggle component for dark mode switching
import ThemeToggle from '../components/ThemeToggle.astro';

// Props = data passed into this component (like function arguments in Python)
interface Props {
  title?: string;  // Optional page title (? means optional)
}

// Destructure props with default value
const { title = "William Hu | Portfolio" } = Astro.props;

// Get current URL path for active link highlighting
// Astro.url.pathname returns the current page path (e.g., "/", "/about")
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Google Fonts (same as your Flask site) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Ma+Shan+Zheng&display=swap" rel="stylesheet" />

    <!-- Your CSS file (now at /css/styles.css instead of /static/css/styles.css) -->
    <link rel="stylesheet" href="/css/styles.css" />

    <!--
      ClientRouter enables smooth page transitions (like a native app)
      When you click a link, instead of a full page reload:
      1. The old page fades out
      2. The new page fades in
      This creates a much smoother user experience!
    -->
    <ClientRouter />

    <!--
      Inline script to prevent "flash of wrong theme"
      This runs BEFORE the page renders, so users don't see a flash
      of light mode if they prefer dark mode (or vice versa)

      is:inline = don't bundle this, run it immediately
    -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Theme toggle button (top-right corner) -->
    <ThemeToggle />

    <!-- Header with navigation -->
    <header class="header">
      <nav class="nav">
        <!--
          Active link logic:
          In Jinja2: class="nav__link {{'nav__link--active' if request.path == url_for('home')}}"
          In Astro: class:list lets us conditionally add classes
        -->
        <a
          href="/"
          class:list={["nav__link", { "nav__link--active": currentPath === "/" }]}
        >
          About
        </a>

        <a
          href="/experience"
          class:list={["nav__link", { "nav__link--active": currentPath === "/experience" }]}
        >
          Experience
        </a>

        <a
          href="/projects"
          class:list={["nav__link", { "nav__link--active": currentPath.startsWith("/projects") }]}
        >
          Projects
        </a>
      </nav>
    </header>

    <!-- Two-column layout: Profile sidebar (left) + Page content (right) -->
    <div class="layout">
      <!-- Left: Profile Sidebar (appears on all pages) -->
      <aside class="profile-sidebar">
        <div class="profile-sidebar__inner">
          <img class="profile__image" src="/img/headshot.jpg" alt="ChiWei Hu headshot" />

          <h1 class="profile__name">ChiWei Hu (William)</h1>
          <p class="profile__name-chinese">胡齊崴</p>

          <!-- Social Links - Icons only -->
          <div class="social-links">
            <a href="/Resume.pdf" class="social-link" target="_blank" aria-label="Resume" title="Resume">
              <svg class="social-link__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
              </svg>
            </a>
            <a href="https://github.com/KiwiHu0923" class="social-link" target="_blank" aria-label="GitHub" title="GitHub">
              <svg class="social-link__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/in/william-hu-922261247/" class="social-link" target="_blank" aria-label="LinkedIn" title="LinkedIn">
              <svg class="social-link__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </a>
            <a href="mailto:chiweih@usc.edu" class="social-link" aria-label="Email" title="Email">
              <svg class="social-link__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </a>
          </div>
        </div>
      </aside>

      <!-- Right: Page content slot - child pages inject their content here -->
      <div class="page-content">
        <slot />
      </div>
    </div>
  </body>
</html>

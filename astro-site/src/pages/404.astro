---
// 404.astro - Custom error page
// This is equivalent to your Flask 404.html template
//
// In Astro, naming a file "404.astro" automatically makes it the 404 error page
// URL: Shows when any page is not found

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <main class="main main--error">
    <h1>404 - Page Not Found</h1>
    <p>
      Sorry, we couldn't find the page you're looking for.
      It may have been mis-spelled, or it doesn't exist anymore.
    </p>
    <!--
      Link changed from:
      {{ url_for('home') }}  →  /

      In Astro, just use the actual URL path
    -->
    <a href="/">Go to home</a>
  </main>
</BaseLayout>

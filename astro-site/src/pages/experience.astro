---
// experience.astro - Experience page
// Displays education history and work/internship experience

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Experience | William Hu">
  <div class="experience">
    <!-- Education Section -->
    <section class="experience__section">
      <h2 class="experience__heading">Education</h2>

      <div class="experience__item">
        <div class="experience__header">
          <h3 class="experience__title">M.S. in Computer Science</h3>
          <span class="experience__date">2023 - Present</span>
        </div>
        <p class="experience__org">University of Southern California (USC)</p>
        <ul class="experience__details">
          <li>Focus on data science and software engineering</li>
        </ul>
      </div>

      <div class="experience__item">
        <div class="experience__header">
          <h3 class="experience__title">M.S. in Biology</h3>
          <span class="experience__date">2019 - 2021</span>
        </div>
        <p class="experience__org">National Taiwan University (NTU)</p>
        <ul class="experience__details">
          <li><!-- Add details here --></li>
        </ul>
      </div>

      <div class="experience__item">
        <div class="experience__header">
          <h3 class="experience__title">B.S. in Biology</h3>
          <span class="experience__date">2015 - 2019</span>
        </div>
        <p class="experience__org">National Cheng Kung University (NCKU)</p>
        <ul class="experience__details">
          <li><!-- Add details here --></li>
        </ul>
      </div>
    </section>

    <!-- Work Experience Section -->
    <section class="experience__section">
      <h2 class="experience__heading">Work Experience</h2>

      <div class="experience__item">
        <div class="experience__header">
          <h3 class="experience__title"><!-- Job Title --></h3>
          <span class="experience__date"><!-- Date Range --></span>
        </div>
        <p class="experience__org"><!-- Company Name --></p>
        <ul class="experience__details">
          <li><!-- Add responsibilities/achievements here --></li>
        </ul>
      </div>

      <!-- Add more work experience items as needed -->
    </section>
  </div>
</BaseLayout>
